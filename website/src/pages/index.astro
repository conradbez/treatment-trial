---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Curtin University is recruiting participants for an OCD treatment trial. Find out if you are eligible and how to participate." />
		<title>OCD Treatment Trial — Curtin University</title>
		<style>
			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

			:root {
				--gold: #CFAC5E;
				--gold-light: #F5EDD6;
				--navy: #1A2B4A;
				--navy-mid: #2C3E6B;
				--text: #1F2937;
				--muted: #6B7280;
				--border: #E5E7EB;
				--white: #FFFFFF;
				--radius: 12px;
			}

			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				color: var(--text);
				line-height: 1.6;
				background: var(--white);
			}

			/* NAV */
			nav {
				background: var(--navy);
				padding: 0 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				height: 64px;
				position: sticky;
				top: 0;
				z-index: 100;
			}
			.nav-logo {
				color: var(--white);
				font-weight: 700;
				font-size: 1rem;
				text-decoration: none;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.nav-logo span { color: var(--gold); }
			.nav-cta {
				background: var(--gold);
				color: var(--navy);
				font-weight: 700;
				font-size: 0.875rem;
				padding: 0.5rem 1.25rem;
				border-radius: 6px;
				text-decoration: none;
			}

			/* HERO */
			.hero {
				background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
				color: var(--white);
				padding: 5rem 2rem 4rem;
				text-align: center;
			}
			.hero-badge {
				display: inline-block;
				background: var(--gold);
				color: var(--navy);
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				padding: 0.35rem 1rem;
				border-radius: 999px;
				margin-bottom: 1.5rem;
			}
			.hero h1 {
				font-size: clamp(2rem, 5vw, 3.25rem);
				font-weight: 800;
				line-height: 1.15;
				max-width: 720px;
				margin: 0 auto 1.25rem;
			}
			.hero h1 em { color: var(--gold); font-style: normal; }
			.hero p {
				font-size: 1.125rem;
				color: rgba(255,255,255,0.82);
				max-width: 560px;
				margin: 0 auto 2.5rem;
			}
			.hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
			.btn-primary {
				background: var(--gold);
				color: var(--navy);
				font-weight: 700;
				font-size: 1rem;
				padding: 0.85rem 2rem;
				border-radius: 8px;
				text-decoration: none;
				transition: opacity 0.15s;
			}
			.btn-primary:hover { opacity: 0.88; }
			.btn-outline {
				border: 2px solid rgba(255,255,255,0.5);
				color: var(--white);
				font-weight: 600;
				font-size: 1rem;
				padding: 0.85rem 2rem;
				border-radius: 8px;
				text-decoration: none;
				transition: border-color 0.15s;
			}
			.btn-outline:hover { border-color: var(--white); }

			/* CONTENT SECTIONS */
			.section { padding: 4.5rem 2rem; max-width: 900px; margin: 0 auto; }
			.section + .section { border-top: 1px solid var(--border); }
			h2 {
				font-size: 1.75rem;
				font-weight: 700;
				color: var(--navy);
				margin-bottom: 1rem;
			}
			p { margin-bottom: 1rem; color: var(--text); }
			p:last-child { margin-bottom: 0; }

			/* CRITERIA CARDS */
			.cards {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
				gap: 1.25rem;
				margin-top: 2rem;
			}
			.card {
				background: var(--white);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1.5rem;
			}
			.card-icon {
				font-size: 1.75rem;
				margin-bottom: 0.75rem;
			}
			.card h3 {
				font-size: 1rem;
				font-weight: 700;
				color: var(--navy);
				margin-bottom: 0.5rem;
			}
			.card p { font-size: 0.9rem; color: var(--muted); margin: 0; }

			/* HIGHLIGHT BAND */
			.highlight {
				background: var(--gold-light);
				border-left: 4px solid var(--gold);
				border-radius: var(--radius);
				padding: 1.5rem 1.75rem;
				margin-top: 2rem;
			}
			.highlight p { color: var(--navy); font-weight: 500; margin: 0; }

			/* PROCESS STEPS */
			.steps { list-style: none; margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
			.steps li {
				display: flex;
				gap: 1rem;
				align-items: flex-start;
			}
			.step-num {
				flex-shrink: 0;
				width: 2rem;
				height: 2rem;
				background: var(--navy);
				color: var(--white);
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-weight: 700;
				font-size: 0.875rem;
			}
			.step-body h3 { font-size: 1rem; font-weight: 700; color: var(--navy); }
			.step-body p { font-size: 0.9rem; color: var(--muted); margin: 0.25rem 0 0; }

			/* CONTACT / CTA BAND */
			.cta-band {
				background: var(--navy);
				color: var(--white);
				text-align: center;
				padding: 4rem 2rem;
			}
			.cta-band h2 { color: var(--white); margin-bottom: 0.75rem; }
			.cta-band p { color: rgba(255,255,255,0.75); max-width: 520px; margin: 0 auto 2rem; }
			.cta-band a.btn-primary { display: inline-block; }
			.contact-detail {
				margin-top: 2rem;
				font-size: 0.9rem;
				color: rgba(255,255,255,0.6);
			}
			.contact-detail a { color: var(--gold); text-decoration: none; }

			/* FOOTER */
			footer {
				background: #111827;
				color: rgba(255,255,255,0.45);
				text-align: center;
				font-size: 0.8rem;
				padding: 1.5rem 2rem;
			}
			footer a { color: var(--gold); text-decoration: none; }

			/* ANCHORS */
			[id] { scroll-margin-top: 80px; }
		</style>
	</head>
	<body>

		<!-- NAV -->
		<nav>
			<a class="nav-logo" href="/">
				Curtin <span>Research</span>
			</a>
			<a class="nav-cta" href="#apply">Express Interest</a>
		</nav>

		<!-- HERO -->
		<section class="hero">
			<div class="hero-badge">Now Recruiting</div>
			<h1>A New Treatment for <em>OCD</em> — Join Our Research Trial</h1>
			<p>Curtin University is seeking adults who experience obsessive-compulsive disorder to participate in a funded clinical research study.</p>
			<div class="hero-actions">
				<a class="btn-primary" href="#apply">Check If I'm Eligible</a>
				<a class="btn-outline" href="#about">Learn More</a>
			</div>
		</section>

		<!-- ABOUT -->
		<div id="about">
			<div class="section">
				<h2>About the Study</h2>
				<p>
					This study is run by researchers at <strong>Curtin University</strong> and aims to evaluate a structured psychological treatment for obsessive-compulsive disorder (OCD). We are investigating whether this approach can help reduce OCD symptoms and improve daily functioning.
				</p>
				<p>
					Participation involves attending sessions with a trained clinician over several weeks. The treatment is evidence-based, and all sessions are provided free of charge to eligible participants.
				</p>
				<div class="highlight">
					<p>All treatment sessions are provided at <strong>no cost</strong> to participants. You may also receive a small reimbursement for your time.</p>
				</div>
			</div>
		</div>

		<!-- ELIGIBILITY -->
		<div id="eligibility">
			<div class="section">
				<h2>Who Can Participate?</h2>
				<p>You may be eligible if you meet the following criteria:</p>
				<div class="cards">
					<div class="card">
						<div class="card-icon">🗓️</div>
						<h3>Age 18 or older</h3>
						<p>The study is open to adults aged 18 and above.</p>
					</div>
					<div class="card">
						<div class="card-icon">🧠</div>
						<h3>Experiencing OCD symptoms</h3>
						<p>You currently experience obsessions, compulsions, or both that affect your daily life.</p>
					</div>
					<div class="card">
						<div class="card-icon">📍</div>
						<h3>Located in Perth, WA</h3>
						<p>Able to attend in-person sessions at the Curtin University campus in Bentley.</p>
					</div>
					<div class="card">
						<div class="card-icon">🌏</div>
						<h3>Fluent in English</h3>
						<p>Sessions and assessments are conducted in English.</p>
					</div>
				</div>
			</div>
		</div>

		<!-- PROCESS -->
		<div id="process">
			<div class="section">
				<h2>What's Involved?</h2>
				<p>Here is what you can expect if you decide to participate:</p>
				<ul class="steps">
					<li>
						<div class="step-num">1</div>
						<div class="step-body">
							<h3>Express Interest</h3>
							<p>Fill in a short online form below. This takes about 5 minutes and does not commit you to anything.</p>
						</div>
					</li>
					<li>
						<div class="step-num">2</div>
						<div class="step-body">
							<h3>Screening Call</h3>
							<p>A researcher will contact you for a brief phone screen to confirm eligibility.</p>
						</div>
					</li>
					<li>
						<div class="step-num">3</div>
						<div class="step-body">
							<h3>Baseline Assessment</h3>
							<p>You will complete a structured interview and questionnaires to assess current symptoms.</p>
						</div>
					</li>
					<li>
						<div class="step-num">4</div>
						<div class="step-body">
							<h3>Treatment Sessions</h3>
							<p>Weekly sessions with a clinician over the course of the trial program.</p>
						</div>
					</li>
					<li>
						<div class="step-num">5</div>
						<div class="step-body">
							<h3>Follow-up Assessment</h3>
							<p>Brief check-ins at the end of treatment and at follow-up to measure outcomes.</p>
						</div>
					</li>
				</ul>
			</div>
		</div>

		<!-- CTA / APPLY -->
		<section class="cta-band" id="apply">
			<h2>Ready to Find Out More?</h2>
			<p>Express your interest and a member of our research team will be in touch within a few business days.</p>
			<a class="btn-primary" href="mailto:ocd.trial@curtin.edu.au?subject=OCD%20Trial%20%E2%80%94%20Expression%20of%20Interest">Email Us to Apply</a>
			<div class="contact-detail">
				Or contact us directly: <a href="mailto:ocd.trial@curtin.edu.au">ocd.trial@curtin.edu.au</a>
				&nbsp;·&nbsp; School of Population Health, Curtin University
			</div>
		</section>

		<!-- FOOTER -->
		<footer>
			<p>© 2026 Curtin University · School of Population Health · This study has received ethics approval from the Curtin University Human Research Ethics Committee.</p>
		</footer>

	</body>
</html>
